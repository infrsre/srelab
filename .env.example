# ── Kiro SRE Guide — CI/CD Environment Variables ─────────────────────────────
#
# Copy to .env.local for local overrides (never commit .env or .env.local).
# In GitLab, add these under Settings → CI/CD → Variables.
# Mark AWS_SECRET_ACCESS_KEY as [Masked] so it never appears in job logs.
#
# Run `terraform output` inside infra/ after `terraform apply` to get values
# for AWS_S3_BUCKET, AWS_CF_DISTRIBUTION_ID, and AWS_ACCOUNT_ID.

# ── AWS credentials (from: terraform output cicd_access_key_id / secret) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS resource IDs ──────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=          # 12-digit: terraform output aws_account_id
AWS_REGION=us-east-1
AWS_S3_BUCKET=           # terraform output s3_bucket_name
AWS_CF_DISTRIBUTION_ID=  # terraform output cloudfront_distribution_id

# ── Docusaurus build target ───────────────────────────────────────────────────
# /            → AWS / Docker (served at root domain)
# /sreluger-project/  → GitLab Pages
DOCUSAURUS_BASE_URL=/

# Optional — overrides the canonical URL embedded in the build
# SITE_URL=https://your-custom-domain.com
