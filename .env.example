# ── Kiro SRE Guide — Environment Variables ───────────────────────────────────
#
# For local overrides: copy to .env.local (never commit .env or .env.local).
#
# For GitHub Actions: add these under
#   Settings → Secrets and variables → Actions → New repository secret
#
# Run `terraform output` inside infra/ after `terraform apply` to get the
# AWS_S3_BUCKET, AWS_CF_DISTRIBUTION_ID, and AWS_ACCOUNT_ID values.

# ── AWS credentials (terraform output cicd_access_key_id / secret) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS resource IDs ──────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=          # terraform output aws_account_id
AWS_REGION=us-east-1
AWS_S3_BUCKET=           # terraform output s3_bucket_name
AWS_CF_DISTRIBUTION_ID=  # terraform output cloudfront_distribution_id

# ── Docusaurus build target (local overrides only) ────────────────────────────
# /   → AWS / Docker (served at root domain)
# The GitHub Actions workflow sets this automatically per-job via configure-pages
DOCUSAURUS_BASE_URL=/
